<div class="min-h-screen bg-gray-50">
  <%- include('../partials/nav.ejs') %>
  <main class="max-w-7xl mx-auto px-4 py-8">
    <h1 class="text-2xl font-bold mb-6">提示词管理</h1>
    <% if (error) { %>
      <div class="text-red-500 mb-4"><%= error %></div>
    <% } %>
    <div class="bg-white rounded shadow overflow-x-auto">
      <table class="w-full text-left">
        <thead class="bg-gray-100">
          <tr>
            <th class="p-3">ID</th>
            <th class="p-3">标题</th>
            <th class="p-3">内容</th>
            <th class="p-3">分类</th>
            <th class="p-3">状态</th>
            <th class="p-3">操作</th>
          </tr>
        </thead>
        <tbody>
          <% prompts.forEach(function(p) { %>
            <tr class="border-t">
              <td class="p-3"><%= p.id %></td>
              <td class="p-3"><%= p.title || '-' %></td>
              <td class="p-3 truncate max-w-xs"><%= p.content %></td>
              <td class="p-3"><%= p.category || '-' %></td>
              <td class="p-3"><%= p.is_enabled ? '启用' : '禁用' %></td>
              <td class="p-3 space-x-3">
                <a href="/admin/prompts/<%= p.id %>/edit" class="text-blue-600 hover:underline">编辑</a>
                <form method="post" action="/admin/prompts/<%= p.id %>/toggle" class="inline">
                  <button type="submit" class="text-sm text-gray-600 hover:text-gray-900">
                    <%= p.is_enabled ? '禁用' : '启用' %>
                  </button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </main>
</div>
