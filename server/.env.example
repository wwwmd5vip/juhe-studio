# ============================================================
# Juhe Management Server — 生产环境配置模板
# 复制此文件为 .env 并填入真实值后使用
# ============================================================

# ── Server ──
PORT=7075
ENV=production

# ── MySQL ──
DB_HOST=127.0.0.1
DB_PORT=7073
DB_USER=juhe
DB_PASSWORD=changeme
DB_NAME=juhe_management
DB_CHARSET=utf8mb4

# ── MySQL Connection Pool ──
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME=300
DB_CONN_MAX_IDLE_TIME=60

# ── Security ──
# 生产环境务必设置强随机值 (openssl rand -base64 64)
JWT_SECRET=changeme-please-generate-a-strong-random-secret
BCRYPT_COST=10

# ── Root Admin (仅首次启动种子创建) ──
ROOT_USERNAME=root
ROOT_PASSWORD=changeme

# ── Password Policy ──
MIN_PASSWORD_LENGTH=8

# ── CORS ──
CORS_ALLOWED_ORIGINS=*

# ── Webhook 签名密钥 ──
WEBHOOK_SECRET=changeme-please-generate-a-strong-random-secret

# ── HTTP Server Timeouts (秒) ──
HTTP_READ_TIMEOUT=30
HTTP_WRITE_TIMEOUT=600
HTTP_IDLE_TIMEOUT=120
HTTP_READ_HEADER_TIMEOUT=10

# ── Request Limits ──
MAX_REQUEST_BODY_BYTES=10485760

# ── Logging ──
LOG_LEVEL=info
LOG_FILE=logs/server.log
LOG_RETENTION_DAYS=90

# ── Scheduler ──
SCHEDULER_ENABLED=true
SCHEDULER_SCHEDULE=0 2 * * *

# ── Channel Health Check ──
HEALTH_CHECK_ENABLED=false
HEALTH_CHECK_INTERVAL=*/5 * * * *
HEALTH_CHECK_TIMEOUT=10
HEALTH_CHECK_THRESHOLD=3
HEALTH_CHECK_CONCURRENCY=10

# ── Channel Retry ──
CHANNEL_RETRY_MAX=2

# ── SMTP (可选 — 留空禁用) ──
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@juhe.studio
